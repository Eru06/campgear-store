# Internal zone VM (192.168.1.30) — production environment
# Copy to .env and fill in real values. NEVER commit .env to git.

# Database
DB_PASSWORD=CHANGE-ME-strong-random-password

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING

# CORS — allow only the DMZ frontend origin
CORS_ORIGINS=http://192.168.2.10,https://192.168.2.10
