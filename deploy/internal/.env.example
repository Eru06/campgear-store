# Internal zone VM (192.168.1.30) — production environment
# Copy to .env and fill in real values. NEVER commit .env to git.

# Database
DB_PASSWORD=CHANGE-ME-strong-random-password

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING

# CORS — allow only the DMZ frontend origin
CORS_ORIGINS=http://192.168.2.10,https://192.168.2.10,https://shop.matcsecdesignd.com

# Keycloak OIDC (SSO for staff admin login)
KEYCLOAK_CLIENT_ID=ecommerce-backend
KEYCLOAK_CLIENT_SECRET=CHANGE-ME-TO-KEYCLOAK-CLIENT-SECRET
KEYCLOAK_AUTH_URL=https://192.168.1.121:8443/realms/internal/protocol/openid-connect/auth
KEYCLOAK_TOKEN_URL=https://192.168.1.121:8443/realms/internal/protocol/openid-connect/token
KEYCLOAK_USERINFO_URL=https://192.168.1.121:8443/realms/internal/protocol/openid-connect/userinfo
KEYCLOAK_REDIRECT_URI=https://shop.matcsecdesignd.com/api/v1/auth/sso/callback
KEYCLOAK_VERIFY_SSL=false
FRONTEND_URL=https://shop.matcsecdesignd.com
